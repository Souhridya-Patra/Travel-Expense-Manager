# Frontend Environment Variables

# ML Service URL - Backend ANI for receipt OCR and item parsing
# Local development (assuming ML service runs on port 8001)
VITE_ML_SERVICE_URL=http://localhost:8001

# Production (uncomment and update for production)
# VITE_ML_SERVICE_URL=https://api.yourapp.com/ml

# API Gateway URL for user auth and expense management
# Local development
VITE_API_GATEWAY_URL=http://localhost:8000

# Production
# VITE_API_GATEWAY_URL=https://api.yourapp.com
